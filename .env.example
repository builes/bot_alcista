# Capital inicial para backtesting
INITIAL_CAPITAL=100000.0

# Configuración de riesgo por defecto
RISK_PER_TRADE=0.01
MAX_DRAWDOWN=0.20
MAX_CONCURRENT_POSITIONS=3
MIN_TRADE_INTERVAL_DAYS=3

# Parámetros de stops
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.06
BREAK_EVEN_TRIGGER_PCT=0.01
TRAILING_ACTIVATION_PCT=0.015
TRAILING_DISTANCE_PCT=0.015

# Parámetros de estrategia (EMA crossover + ADX)
EMA_FAST=50
EMA_SLOW=200
ADX_PERIOD=14
ADX_THRESHOLD=25
VOLUME_WINDOW=20
VOLUME_THRESHOLD=1.0
PULLBACK_TOLERANCE=0.01

# Exchange (futura conexión)
EXCHANGE_NAME=binance
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
SYMBOLS=BTC/USDT,ETH/USDT
TIMEFRAME=1h
